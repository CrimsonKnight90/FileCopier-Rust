--- .gitignore
# Dependencies
target/
**/target/

# Compiled files
*.dll
*.so
*.dylib
*.exe
*.o
*.obj
*.a
*.lib

# Rust-specific
Cargo.lock
**/Cargo.lock
**/*.rs.bk
**/.*.rs.swp

# Logs
*.log

# Temporary files
*.tmp
*.temp

# Environment
.env
.env.local
.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo

# Coverage
coverage/
htmlcov/
.coverage

# OS
.DS_Store
Thumbs.db

# MyPy
.mypy_cache/

# PyTest
.pytest_cache/

# Gradle
.gradle/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst

